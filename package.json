    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "fast-text-encoding": "^1.0.6",
    "fast-xml-parser": "^5.8.0",
    "jsonpath-plus": "^10.4.0",
    "micromatch": "^4.0.8",
    "mysql2": "^3.12.0",
    "pg": "^8.11.0",
