    "pg": "^8.11.0",
    "ws": "^8.21.0",
    "yaml": "^2.9.0",
    "yargs-parser": "^22.0.0"
  },
  "devDependencies": {
    "@clack/prompts": "^0.10.0",
    "archiver": "^8.0.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.0.0",
    "esbuild": "^0.28.0",
    "jsonpath-plus": "^10.4.0",
    "micromatch": "^4.0.8",
    "tar": "^7.5.15",
    "tinyglobby": "^0.2.12",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
