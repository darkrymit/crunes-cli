{
  "name": "@darkrymit/crunes-cli",
  "version": "0.5.10",
  "description": "CLI tool for querying crunes enrichers",
  "type": "module",
  "bin": {
    "crunes": "./dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "typedoc --options typedoc.json && typedoc --options typedoc-lifecycle.json && typedoc --options typedoc-globals.json && node build.mjs",
