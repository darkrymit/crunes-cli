{
  "runes": {
    "release": {
      "path": ".crunes/runes/release.js",
      "name": "Release Automator",
      "description": "Bump package versions, update changelogs, synchronize lockfiles, compile bundles, and tag Git releases automatically.",
      "permissions": {
        "use": {
          "allow": [
            "fs.read:package.json",
            "fs.read:package-lock.json",
            "fs.read:src/cli/program.js",
            "fs.read:CHANGELOG.md",
            "fs.write:package.json",
            "fs.write:src/cli/program.js",
            "fs.write:CHANGELOG.md",
            "shell.exec:git log *",
            "shell.exec:git rev-parse *",
            "shell.exec:git describe *",
            "shell.exec:git rev-list *",
            "shell.exec:npm install",
            "shell.exec:npm run build",
            "shell.exec:git add package.json",
            "shell.exec:git add package-lock.json",
            "shell.exec:git add CHANGELOG.md",
            "shell.exec:git add src/cli/program.js",
            "shell.exec:git commit *",
            "shell.exec:git tag *"
          ]
        }
      }
    },
    "m": {
      "path": ".crunes/runes/m.js",
      "name": "Module Structural Context",
      "description": "Live structural context (README and file tree) for modules.",
      "permissions": {
        "use": {
          "allow": [
            "fs.read:src/**",
            "fs.glob:src/**",
            "fs.exists:src/**"
          ]
        }
      }
    },
    "kb": {
      "path": ".crunes/runes/kb.js",
      "name": "Knowledge Base Context",
      "description": "Deep narrative context (Key Decisions, Gotchas) from the docs/knowledge-base.",
      "permissions": {
        "use": {
          "allow": [
            "fs.read:docs/knowledge-base/**",
            "fs.glob:docs/knowledge-base/**",
            "fs.exists:docs/knowledge-base/**"
          ]
        }
      }
    }
  },
  "plugins": [
    "crunes-plugins@git"
  ]
}